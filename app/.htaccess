# BEGIN Shopping Intellect app + WordPress coexistence
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# This host's PHP runtime strips the Authorization header before it reaches
# PHP (common on FastCGI/PHP-FPM-via-Apache setups), which broke every JWT
# bearer-auth request (si/v1 list/item endpoints) with "Missing bearer token".
# Forward it explicitly.
RewriteCond %{HTTP:Authorization} ^(.+)
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Serve existing WordPress/app files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route the REST API and WordPress admin/login through WP's front controller
RewriteCond %{REQUEST_URI} ^/(wp-admin/|wp-json|xmlrpc\.php) [NC]
RewriteRule ^(wp-admin/.*\.php)$ $1 [L]
RewriteRule ^ index.php [L]

# Everything else (app routes) falls back to the SPA shell
RewriteRule ^ index.html [L]
</IfModule>
# END Shopping Intellect app + WordPress coexistence
