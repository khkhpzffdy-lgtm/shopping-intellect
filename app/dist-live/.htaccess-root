AddHandler ${application/x-httpd-propmbgp-php85} .php .php5 .phtml .php7 .php8

<FilesMatch "xmlrpc\.php$">
order deny,allow
deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# WordPress/API/system routes must bypass the SPA shell.
RewriteRule ^wp-json(/.*)?$ /index.php [L,QSA]
RewriteRule ^wp-admin(/.*)?$ - [L]
RewriteRule ^wp-content(/.*)?$ - [L]
RewriteRule ^wp-includes(/.*)?$ - [L]
RewriteRule ^wp-login\.php$ - [L]
RewriteRule ^wp-cron\.php$ - [L]
RewriteRule ^wp-.*\.php$ - [L]
RewriteRule ^xmlrpc\.php$ - [L]
RewriteRule ^wp$ - [L]
RewriteRule ^wp/.*$ - [L]

# Let real files and directories resolve normally first.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else belongs to the SPA shell.
RewriteRule ^ /index.html [L]
</IfModule>
